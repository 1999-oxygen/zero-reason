import cv2
import json
import sqlite3
import asyncio
from fastapi import FastAPI, WebSocket, WebSocketDisconnect
from fastapi.middleware.cors import CORSMiddleware
import uvicorn
import numpy as np
import supervision as sv
from ultralytics import YOLO

# 1. Initialize FastAPI
app = FastAPI()

# Allow React to communicate with this backend
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"], # In production, restrict this to your React app's local IP
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# 2. The AI Brain (From our previous step)
class LiquorAIBrain:
    def __init__(self, model_path="yolov8n.pt", db_path="shop_sales.db", frame_resolution=(640, 480)):
        self.db_path = db_path
        self.resolution = frame_resolution
        self.counted_tracker_ids = set()
        
        self.model = YOLO(model_path)
        self.tracker = sv.ByteTrack()
        self._setup_database()

        w, h = self.resolution
        zone_polygon = np.array([[w // 2, h // 2], [w, h // 2], [w, h], [w // 2, h]])
        self.zone = sv.PolygonZone(polygon=zone_polygon, frame_resolution_wh=self.resolution)

    def _setup_database(self):
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        cursor.execute('''CREATE TABLE IF NOT EXISTS products (class_id INTEGER PRIMARY KEY, brand_name TEXT, buying_price REAL, selling_price REAL)''')
        cursor.execute('''CREATE TABLE IF NOT EXISTS sales_log (id INTEGER PRIMARY KEY AUTOINCREMENT, brand_name TEXT, revenue REAL, profit REAL, timestamp DATETIME DEFAULT CURRENT_TIMESTAMP)''')
        
        # Test Data
        cursor.execute('DELETE FROM products') 
        cursor.executemany('INSERT INTO products VALUES (?, ?, ?, ?)', [
            (39, 'Chrome_Vodka_250ml', 180.0, 250.0), # Class 39 = bottle
            (41, 'Tusker_Lager_500ml', 150.0, 220.0)  # Class 41 = cup
        ])
        conn.commit()

    def process_frame(self, frame):
        results = self.model(frame, verbose=False)[0]
        detections = sv.Detections.from_ultralytics(results)
        detections = self.tracker.update_with_detections(detections)
        zone_mask = self.zone.trigger(detections=detections)
        
        new_sales = []
        bounding_boxes = []

        for i, (detection, in_zone) in enumerate(zip(detections, zone_mask)):
            bbox, mask, confidence, class_id, tracker_id = detection
            
            # Format bounding box for React UI [x_min, y_min, x_max, y_max]
            bounding_boxes.append({
                "class_id": int(class_id),
                "box": [float(bbox[0]), float(bbox[1]), float(bbox[2]), float(bbox[3])],
                "in_zone": bool(in_zone)
            })
            
            if in_zone and tracker_id is not None and tracker_id not in self.counted_tracker_ids:
                self.counted_tracker_ids.add(tracker_id)
                conn = sqlite3.connect(self.db_path)
                cursor = conn.cursor()
                cursor.execute('SELECT brand_name, buying_price, selling_price FROM products WHERE class_id = ?', (int(class_id),))
                product = cursor.fetchone()
                
                if product:
                    brand_name, buy, sell = product
                    profit = sell - buy
                    cursor.execute('INSERT INTO sales_log (brand_name, revenue, profit) VALUES (?, ?, ?)', (brand_name, sell, profit))
                    conn.commit()
                    new_sales.append({"brand": brand_name, "revenue": sell, "profit": profit})
                    print(f"💰 SALE: {brand_name}")

        return {"boxes": bounding_boxes, "new_sales": new_sales}

# Initialize Brain
brain = LiquorAIBrain()

# 3. WebSocket Endpoint for React
@app.websocket("/ws/video_feed")
async def video_feed(websocket: WebSocket):
    await websocket.accept()
    cap = cv2.VideoCapture(0) # 0 for webcam, or put RTSP string here
    
    try:
        while True:
            ret, frame = cap.read()
            if not ret:
                break
            
            frame = cv2.resize(frame, (640, 480))
            
            # Run AI
            ai_data = brain.process_frame(frame)
            
            # Compress frame to send to React (Optional: you can also just send boxes and let React draw over a direct camera feed)
            _, buffer = cv2.imencode('.jpg', frame, [cv2.IMWRITE_JPEG_QUALITY, 50])
            frame_base64 = buffer.tobytes().hex() # Simple hex encoding for demo
            
            # Send Data to React
            payload = {
                "boxes": ai_data["boxes"],
                "sales": ai_data["new_sales"]
            }
            await websocket.send_text(json.dumps(payload))
            
            await asyncio.sleep(0.03) # roughly 30 FPS
            
    except WebSocketDisconnect:
        print("React Client Disconnected")
    finally:
        cap.release()

# 4. REST API Endpoint for Daily Profits
@app.get("/api/daily_summary")
def get_daily_summary():
    conn = sqlite3.connect("shop_sales.db")
    cursor = conn.cursor()
    cursor.execute("SELECT SUM(revenue), SUM(profit) FROM sales_log WHERE date(timestamp) = date('now')")
    data = cursor.fetchone()
    return {"today_revenue": data[0] or 0, "today_profit": data[1] or 0}

